@startuml
allowmixing

' Título do diagrama
title Diagrama de Comunicação:\nCaso Expandido 2: Criar Plano de Ação

' Estilização Dark Mode
skinparam backgroundColor #002b2b
skinparam defaultFontColor white
skinparam actor {
    BackgroundColor #002b2b
    BorderColor white
    FontColor white
}
skinparam object {
    BackgroundColor #2b4a22
    BorderColor #86c440
    FontColor white
}
skinparam arrow {
    Color white
    FontColor white
    Thickness 1.5
}

' Declaração dos nós
actor "Gestor Setorial" as Gestor
object ":Sistema" as Sist
object "painel: Painel" as Painel
object "plano: Plano" as Plano

' ==========================================
' MENSAGENS E RELACIONAMENTOS
' ==========================================

' Comunicação exclusiva com o Controlador (Slide 74)
Gestor -right-> Sist : "1: abrirPainel()\n2: criarPlanoAcao()\n3: publicarPlanoAcao()"
Sist .left.> Gestor : "1.1.1: [volume < limite] fecharPainel()\n1.1.1a: [volume < limite] msgDadosInsuficentes()\n1.2: mostrarPainel()\n2.1: formularioPlanoAcao()\n3.3: msgPlanoPublicado()"

' Auto-chamada de controle do sistema
Sist -up-> Sist : "1.1: verificarVolumeDados()"

' Delegação para os Objetos do Domínio
Sist -down-> Painel : "3.2: associarPlano(plano)"
Sist -right-> Plano : "3.1: plano:=criar(dados)"

' Link estrutural de domínio
Painel -- Plano

@enduml